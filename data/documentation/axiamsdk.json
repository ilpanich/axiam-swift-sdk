{"topicSections":[{"identifiers":["doc:\/\/AxiamSDK\/documentation\/AxiamSDK\/AxiamClient","doc:\/\/AxiamSDK\/documentation\/AxiamSDK\/AxiamConfig","doc:\/\/AxiamSDK\/documentation\/AxiamSDK\/ClientCertificate"],"title":"Client"},{"identifiers":["doc:\/\/AxiamSDK\/documentation\/AxiamSDK\/LoginResult","doc:\/\/AxiamSDK\/documentation\/AxiamSDK\/AccessResult","doc:\/\/AxiamSDK\/documentation\/AxiamSDK\/AccessCheck","doc:\/\/AxiamSDK\/documentation\/AxiamSDK\/AxiamUser"],"title":"Results"},{"identifiers":["doc:\/\/AxiamSDK\/documentation\/AxiamSDK\/AxiamError","doc:\/\/AxiamSDK\/documentation\/AxiamSDK\/AuthError","doc:\/\/AxiamSDK\/documentation\/AxiamSDK\/AuthzError","doc:\/\/AxiamSDK\/documentation\/AxiamSDK\/NetworkError"],"title":"Errors"},{"identifiers":["doc:\/\/AxiamSDK\/documentation\/AxiamSDK\/Sensitive"],"title":"Security"},{"identifiers":["doc:\/\/AxiamSDK\/documentation\/AxiamSDK\/AxiamRequestAuthenticator","doc:\/\/AxiamSDK\/documentation\/AxiamSDK\/AxiamRequestContext","doc:\/\/AxiamSDK\/documentation\/AxiamSDK\/AxiamGuards","doc:\/\/AxiamSDK\/documentation\/AxiamSDK\/AxiamGuardHandler"],"title":"Resource-server integration"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"AxiamSDK"},{"type":"text","text":" is a REST client for the AXIAM identity and authorization platform. It conforms to"},{"type":"text","text":" "},{"type":"text","text":"the cross-language "},{"type":"strong","inlineContent":[{"type":"text","text":"CONTRACT.md"}]},{"type":"text","text":" behavioral contract, §1–§7 and §9–§11, including §6.1 mutual"},{"type":"text","text":" "},{"type":"text","text":"TLS (client-certificate authentication)."}]},{"type":"paragraph","inlineContent":[{"text":"The client is an ","type":"text"},{"code":"actor","type":"codeVoice"},{"text":", so its session state — the in-memory cookie jar, the CSRF token, and","type":"text"},{"text":" ","type":"text"},{"text":"the single-flight refresh guard — is safe under concurrent use. Access and refresh tokens are","type":"text"},{"text":" ","type":"text"},{"text":"delivered by the server as ","type":"text"},{"code":"httpOnly","type":"codeVoice"},{"text":" cookies and never handled as raw strings by your code.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let config = try AxiamConfig(","    baseURL: URL(string: \"https:\/\/id.example.com\")!,","    tenantSlug: \"acme\"",")","let client = try AxiamClient(config: config)","","switch try await client.login(email: \"user@example.com\", password: \"correct horse\") {","case .authenticated(let user):","    let canEdit = try await client.can(\"edit\", resource: \"doc-uuid\")","    print(user.userID, canEdit)","case .mfaRequired:","    try await client.verifyMfa(\"123456\")","case .mfaSetupRequired:","    break","}"]},{"anchor":"Scope","type":"heading","level":2,"text":"Scope"},{"type":"paragraph","inlineContent":[{"text":"In scope for v1: §1 methods, §2 error taxonomy, §3 CSRF, §4 cookie jar, §5 tenant context,","type":"text"},{"text":" ","type":"text"},{"text":"§6\/§6.1 TLS + mTLS, §7 ","type":"text"},{"code":"Sensitive","type":"codeVoice"},{"text":", §9 single-flight refresh, §10 route-guard, §11 declarative","type":"text"},{"text":" ","type":"text"},{"text":"helpers, and org-wide EdDSA JWKS verification.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Out of scope for this Swift v1 (documented follow-ups): gRPC transport and §8 AMQP HMAC"},{"type":"text","text":" "},{"type":"text","text":"consumption — the contract does not list AMQP for Swift."}]}]}],"sections":[],"abstract":[{"type":"text","text":"The official Swift SDK for AXIAM (Access eXtended Identity and Authorization Management)."}],"variants":[{"paths":["\/documentation\/axiamsdk"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHe